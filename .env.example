# Local development points at the Postgres in infra/docker-compose.yml.
# In production, point this at a Neon database.
DATABASE_URL=postgresql+psycopg2://finsight:finsight@localhost:5432/finsight

# Gemini analysis.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Retrieval-augmented Q&A. Embeddings reuse GEMINI_API_KEY. EMBED_DIM must
# match the embedding model (text-embedding-004 -> 768).
EMBED_MODEL=text-embedding-004
EMBED_DIM=768
RAG_TOP_K=5

# Optional keyed fallback data provider. Leave blank for yfinance only.
POLYGON_API_KEY=

# Email delivery. Use smtp with a Gmail app password locally, or resend in
# production once you have a transactional provider key.
EMAIL_BACKEND=smtp
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
RESEND_API_KEY=

# Shown in the email footer and needed before opening a public mailing list.
MAILING_ADDRESS=

# Base URL used to build confirm and unsubscribe links.
PUBLIC_BASE_URL=http://localhost:8000

FINSIGHT_TZ=America/Chicago
