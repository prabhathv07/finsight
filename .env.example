# Local development points at the Postgres in infra/docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://finsight:finsight@localhost:5432/finsight

# Gemini analysis. Required from phase 2 onward.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional keyed fallback data provider. Leave blank for yfinance only.
POLYGON_API_KEY=

FINSIGHT_TZ=America/Chicago
